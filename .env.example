# LLM orchestrator: rule_based (default) | openai
LLM_PROVIDER=rule_based
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL (for csv_to_postgresql agent)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ingestion

# Streaming JSON → Parquet / JSON
STREAM_BATCH_SIZE=50

# S3: use local mock folder data/s3-mock/ when true (no AWS credentials needed)
S3_USE_LOCAL=true
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=http://localhost:9000
